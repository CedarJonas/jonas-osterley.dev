---
import { getCollection } from "astro:content";
import Base from "../layouts/Base.astro";
import { getLandingPages } from "../lib/content";

const projects = await getLandingPages();
const experiments = await getCollection("experiments");
---

<Base title="Home">
  <section class="intro">
    <p>
      ML Engineer. I build agentic infrastructure, LLM evaluation systems, and production AI
      pipelines. I go deep across everything I work on.
    </p>
  </section>

  <section class="projects">
    <h2 class="eyebrow">Projects</h2>
    <ul class="project-list">
      {
        projects.map((project) => (
          <li class="project">
            <h3>
              <a href={`/projects/${project.slug}`}>{project.data.title}</a>
            </h3>
            <p class="description">{project.data.description}</p>
            {project.data.tags.length > 0 && <p class="tags">{project.data.tags.join(" · ")}</p>}
          </li>
        ))
      }
    </ul>
  </section>

  {
    experiments.length > 0 && (
      <section class="experiments">
        <h2 class="eyebrow">Experiments</h2>
        <ul class="experiment-grid">
          {experiments.map((experiment) => (
            <li class="experiment">
              <h3>
                {experiment.data.link ? (
                  <a href={experiment.data.link}>{experiment.data.title}</a>
                ) : (
                  experiment.data.title
                )}
              </h3>
              <p class="description">{experiment.data.description}</p>
            </li>
          ))}
        </ul>
      </section>
    )
  }
</Base>

<style>
  .intro {
    margin-bottom: 4rem;
    max-width: 560px;
  }

  .intro p {
    font-size: 1.125rem;
    line-height: 1.7;
    color: var(--text);
  }

  .eyebrow {
    margin-bottom: 0.5rem;
  }

  .project-list,
  .experiment-grid {
    list-style: none;
  }

  .project {
    padding: 1.75rem 0;
    border-bottom: 1px solid var(--border);
  }

  .project:last-child {
    border-bottom: none;
  }

  .project h3 {
    font-size: 1.125rem;
    font-weight: 600;
    margin-bottom: 0.375rem;
  }

  .project h3 a {
    color: var(--heading);
  }

  .project h3 a:hover {
    color: var(--accent);
  }

  .description {
    max-width: 620px;
  }

  .tags {
    margin-top: 0.625rem;
    font-family: var(--font-heading);
    font-size: var(--size-eyebrow);
    color: var(--muted);
    letter-spacing: 0.02em;
  }

  .experiments {
    margin-top: 4rem;
  }

  .experiment-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1.5rem;
    margin-top: 1.25rem;
  }

  .experiment {
    border: 1px solid var(--border);
    padding: 1.25rem 1.375rem;
  }

  .experiment h3 {
    font-size: 1rem;
    font-weight: 600;
    margin-bottom: 0.375rem;
  }
</style>
