---
import Base from "../../../layouts/Base.astro";
import { getLandingPages, getWriteUps, formatDate, type WriteUpEntry } from "../../../lib/content";

export async function getStaticPaths() {
  const writeUps = await getWriteUps();
  return writeUps.map((entry) => {
    const [slug, writeup] = entry.slug.split("/");
    return { params: { slug, writeup }, props: { entry } };
  });
}

type Props = { entry: WriteUpEntry };

const { entry } = Astro.props;
const { Content } = await entry.render();

const projectSlug = entry.slug.split("/")[0];
const parent = (await getLandingPages()).find((project) => project.slug === projectSlug);
---

<Base title={entry.data.title} description={entry.data.description}>
  <article>
    <header>
      {
        parent && (
          <p class="eyebrow">
            <a href={`/projects/${parent.slug}`}>{parent.data.title}</a>
          </p>
        )
      }
      <h1>{entry.data.title}</h1>
      <p class="date">{formatDate(entry.data.date)}</p>
    </header>

    <div class="prose">
      <Content />
    </div>
  </article>
</Base>

<style>
  header {
    margin-bottom: 2.5rem;
  }

  .eyebrow {
    margin-bottom: 0.75rem;
  }

  .eyebrow a {
    color: var(--accent);
  }

  h1 {
    margin-bottom: 0.625rem;
  }

  .date {
    font-family: var(--font-heading);
    font-size: var(--size-eyebrow);
    color: var(--muted);
  }
</style>
