---
import Base from "../../layouts/Base.astro";
import { getLandingPages, getWriteUps, formatDate, type LandingEntry } from "../../lib/content";

export async function getStaticPaths() {
  const projects = await getLandingPages();
  return projects.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

type Props = { entry: LandingEntry };

const { entry } = Astro.props;
const { Content } = await entry.render();
const writeUps = await getWriteUps(entry.slug);
---

<Base title={entry.data.title} description={entry.data.description}>
  <article>
    <header>
      <p class="eyebrow">Project</p>
      <h1>{entry.data.title}</h1>
      <p class="lede">{entry.data.description}</p>
      {
        entry.data.repo && (
          <p class="repo">
            <a href={entry.data.repo}>View the code</a>
          </p>
        )
      }
    </header>

    <div class="prose">
      <Content />
    </div>
  </article>

  {
    writeUps.length > 0 && (
      <section class="write-ups">
        <h2 class="eyebrow">Write-ups</h2>
        <ul>
          {writeUps.map((writeUp) => (
            <li>
              <h3>
                <a href={`/projects/${writeUp.slug}`}>{writeUp.data.title}</a>
              </h3>
              <p class="date">{formatDate(writeUp.data.date)}</p>
              <p>{writeUp.data.description}</p>
            </li>
          ))}
        </ul>
      </section>
    )
  }
</Base>

<style>
  header {
    margin-bottom: 2.5rem;
  }

  .eyebrow {
    margin-bottom: 0.75rem;
  }

  h1 {
    margin-bottom: 1rem;
  }

  .lede {
    font-size: 1.125rem;
    line-height: 1.7;
    color: var(--muted);
  }

  .repo {
    margin-top: 0.75rem;
    font-family: var(--font-heading);
    font-size: var(--size-nav);
  }

  .write-ups {
    margin-top: 4rem;
    padding-top: 2.5rem;
    border-top: 1px solid var(--border);
  }

  .write-ups ul {
    list-style: none;
    margin-top: 1.25rem;
  }

  .write-ups li + li {
    margin-top: 2rem;
  }

  .write-ups h3 {
    font-size: 1.0625rem;
    font-weight: 600;
    margin-bottom: 0.25rem;
  }

  .date {
    font-family: var(--font-heading);
    font-size: var(--size-eyebrow);
    color: var(--muted);
    margin-bottom: 0.375rem;
  }
</style>
